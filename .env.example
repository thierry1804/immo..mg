DATABASE_URL=postgres://geomarket:geomarket@localhost:5432/geomarket
# Reserved for future signed cookies / CSRF (not required yet)
AUTH_SECRET=change-me

REDIS_URL=redis://localhost:6379

# Conversational search (M4). Without a key, a French rule-based extractor is
# used as a fallback — the feature still works, just without the LLM.
OPENAI_API_KEY=

# Email alerts (Resend). Optional — in-app notifications work without it.
RESEND_API_KEY=
EMAIL_FROM=alerts@immo.mg

# Map tiles (optional). Falls back to OSM raster tiles.
MAPTILER_KEY=
NEXT_PUBLIC_MAPTILER_KEY=

# Disable rate limiting (tests / CI)
# RATE_LIMIT_DISABLED=true

SCRAPER_USER_AGENT=ImmoMgBot/0.1 (+contact@immo.mg)
NOMINATIM_URL=https://nominatim.openstreetmap.org
# GEOCODE_SKIP_NETWORK=true  # regeocode batch sans appeler Nominatim (repères + fokontany)
SCRAPE_INTERVAL_HOURS=6
BOOTSTRAP_ADMIN_EMAIL=

# Built-in agency scrapers (set to false to disable)
OFIM_SCRAPER_ENABLED=true
ACROPOLE_SCRAPER_ENABLED=true
ACROPOLE_MAX_PAGES=3
ACROPOLE_FETCH_DETAILS=true
ACROPOLE_EUR_TO_AR_RATE=4800
ETRANO_SCRAPER_ENABLED=true
ETRANO_MAX_PAGES=3
ETRANO_FETCH_DETAILS=true

# Experimental, ToS risks — keep disabled unless you accept the risks
FB_SCRAPER_ENABLED=false
FB_USERNAME=
FB_PASSWORD=

{
  "name": "geomarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:backfill": "tsx --env-file=.env.local scripts/backfill-enrichment.ts",
    "db:sync-dev-passwords": "tsx --env-file=.env.local scripts/sync-dev-passwords.ts",
    "db:regeocode-pending": "tsx --env-file=.env.local scripts/regeocode-pending.ts",
    "worker": "tsx --env-file=.env.local scripts/worker.ts",
    "scrape:once": "tsx --env-file=.env.local scripts/enqueue-once.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "alert:digest": "tsx --env-file=.env.local scripts/alert-digest.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@types/supercluster": "^7.1.3",
    "bullmq": "^5.77.7",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.7",
    "p-throttle": "^8.1.0",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "supercluster": "^8.0.1",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
